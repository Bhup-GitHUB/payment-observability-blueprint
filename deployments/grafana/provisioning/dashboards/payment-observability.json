{
  "title": "Payment System Observability",
  "uid": "payment-observability",
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "schemaVersion": 39,
  "tags": ["payments", "observability"],
  "panels": [
    {
      "id": 1,
      "title": "Payment Throughput (RPS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(payment_requests_total[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "Success Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(payment_requests_total{status=\"completed\"}[5m])) / (sum(rate(payment_requests_total[5m])) + 0.0001) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Failure Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(payment_requests_total{status=\"failed\"}[5m])) / (sum(rate(payment_requests_total[5m])) + 0.0001) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Risk Rejection Rate",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(risk_evaluations_total{decision=\"rejected\"}[5m])) / (sum(rate(risk_evaluations_total[5m])) + 0.0001) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 5,
      "title": "Payment Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(payment_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(payment_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(payment_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 6,
      "title": "Bank Authorization Latency P99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(bank_authorization_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(bank_authorization_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 7,
      "title": "Risk Decisions",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(risk_evaluations_total[1m])",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Bank Authorizations",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bank_authorizations_total[1m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Ledger Writes / Duplicates",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ledger_writes_total{recorded=\"true\"}[1m])",
          "legendFormat": "written"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ledger_duplicates_total[1m])",
          "legendFormat": "duplicates"
        }
      ]
    },
    {
      "id": 10,
      "title": "Notifications Sent",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(notifications_sent_total[1m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "DB Query Latency P95",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 12,
      "title": "Payments by Status (stacked)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(payment_requests_total[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" } } }
      }
    },
    {
      "id": 13,
      "title": "Recent Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\".+\"} | json",
          "queryType": "range"
        }
      ]
    }
  ]
}
